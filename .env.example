# Copiá este archivo a .env y completá los valores.
# SITE_URL debe coincidir con la URL del navegador (Live Server, Firebase Hosting, etc.)

MERCADOPAGO_ACCESS_TOKEN=
# Public Key (solo en servidor y expuesta al navegador vía /api/mp-public-config; no confundir con el Access Token)
MERCADOPAGO_PUBLIC_KEY=
# URL base que el navegador usará en las respuestas JSON (debe coincidir con dónde corre servidor-mp.js)
MP_PUBLIC_ORIGIN=http://localhost:3456
SITE_URL=http://127.0.0.1:5500
PORT_MP=3456
